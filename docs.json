{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "D-Sports Docs",
  "description": "Documentation for the D-Sports fan engagement platform.",
  "colors": {
    "primary": "#F5C842",
    "light": "#FDE68A",
    "dark": "#D4A84B"
  },
  "favicon": "/favicon.svg",
  "logo": "/logo/d-sports-logo.png",
  "thumbnails": {
    "background": "/images/og-image.png"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "development",
              "repositories/ecosystem-overview"
            ]
          },
          {
            "group": "Repositories",
            "pages": [
              "repositories/d-sports-api",
              "repositories/d-sports-site",
              "repositories/d-sports-engage-native",
              "repositories/d-sports-mic-d-up"
            ]
          },
          {
            "group": "Docs configuration",
            "pages": [
              "essentials/settings",
              "essentials/navigation"
            ]
          },
          {
            "group": "Writing D-Sports docs",
            "pages": [
              "essentials/markdown",
              "essentials/code",
              "essentials/images",
              "essentials/reusable-snippets"
            ]
          },
          {
            "group": "AI assistants",
            "pages": [
              "ai-tools/cursor",
              "ai-tools/claude-code",
              "ai-tools/windsurf"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API documentation",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoint examples",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://d-sports.org",
          "icon": "globe"
        },
        {
          "anchor": "App",
          "href": "https://app.d-sports.org",
          "icon": "rocket"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:contact@d-sports.org"
      }
    ],
    "primary": {
      "type": "button",
      "label": "App",
      "href": "https://app.d-sports.org"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/dsportsorg",
      "github": "https://github.com/d-sports",
      "website": "https://d-sports.org"
    }
  }
}
